model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  image_url   String?
  subCategories SubCategory[]

  products     Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([id])
  @@map("categories")
}

model SubCategory {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  categoryId   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category     Category  @relation(fields: [categoryId], references: [id])
  products     Product[]

  @@index([id])
  @@map("sub_categories")
}
model ContactRequest {
    id Int @id @default(autoincrement())
    name String
    email String
    phone String
    subject String
    message String
    reply String?
    status ContactStatus @default(PENDING)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("contact_requests")
}

enum ContactStatus {
    PENDING
    REPLIED
}